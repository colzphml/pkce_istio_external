LOG_LEVEL=info

SERVER_HTTP_ADDR=:8080
SERVER_GRPC_ADDR=:9090

OIDC_ISSUER_URL=https://keycloak.example.com/realms/main
OIDC_CLIENT_ID=oidc-auth
OIDC_CLIENT_SECRET=replace-me
OIDC_SCOPES=openid,profile,email,offline_access
OIDC_LOGIN_PATH=/_auth/login
OIDC_CALLBACK_PATH=/_auth/callback
OIDC_LOGOUT_PATH=/_auth/logout
OIDC_BACKCHANNEL_LOGOUT_PATH=/_auth/backchannel-logout
OIDC_POST_LOGOUT_PATH=/
OIDC_LOGIN_STATE_TTL=10m
OIDC_REFRESH_WINDOW=2m
OIDC_HTTP_TIMEOUT=5s
OIDC_CLOCK_SKEW=30s
OIDC_ACCESS_TOKEN_AUDIENCES=oidc-auth

SESSION_ALLOWED_HOSTS=app.example.com
SESSION_COOKIE_NAME=__Host-oidc_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_MAX_LIFETIME=12h
SESSION_MIN_ACCESS_TOKEN_TTL=10s

REDIS_MODE=sentinel
REDIS_ADDRESSES=oidc-auth-redis.auth.svc.cluster.local:26379
REDIS_MASTER_NAME=mymaster
REDIS_USERNAME=authsvc
REDIS_PASSWORD=replace-me
REDIS_SENTINEL_USERNAME=authsvc
REDIS_SENTINEL_PASSWORD=replace-me
REDIS_DB=0
REDIS_KEY_PREFIX=oidc:
REDIS_TLS_ENABLED=true
REDIS_TLS_SERVER_NAME=oidc-auth-redis.auth.svc.cluster.local
REDIS_TLS_INSECURE_SKIP_VERIFY=false
REDIS_TLS_CA_FILE=/var/run/redis-tls/ca.crt
REDIS_DIAL_TIMEOUT=2s
REDIS_READ_TIMEOUT=2s
REDIS_WRITE_TIMEOUT=2s
REDIS_POOL_SIZE=64
REDIS_MIN_IDLE_CONNS=16
REDIS_REFRESH_LOCK_TTL=15s
REDIS_REFRESH_LOCK_WAIT_TIMEOUT=2s
REDIS_REFRESH_LOCK_POLL_INTERVAL=50ms
